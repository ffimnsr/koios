# Koios environment variables.
# Copy to .env and uncomment what you need. Variables are sorted alphabetically.

# Directory for persisted subagent run records.
# Default: "" (disabled)
# AGENT_DIR=./data/agents

# Maximum concurrent child runs spawned from one parent agent run.
# Default: 4
# AGENT_MAX_CHILDREN=4

# Maximum number of retry attempts for agent runtime provider calls.
# Default: 3
# AGENT_RETRY_ATTEMPTS=3

# Initial retry backoff for agent runtime provider calls (Go duration string).
# Default: 500ms
# AGENT_RETRY_INITIAL_BACKOFF=500ms

# Maximum retry backoff for agent runtime provider calls (Go duration string).
# Default: 5s
# AGENT_RETRY_MAX_BACKOFF=5s

# Number of most-recent messages kept verbatim after compaction.
# The remaining older messages are summarized.
# Default: 20
# COMPACTION_RESERVE=20

# Number of stored messages that triggers LLM summarization of older turns.
# Set to 0 to disable compaction.
# Default: 0
# COMPACTION_THRESHOLD=80

# Directory for cron job persistence.
# Jobs are stored at <CRON_DIR>/jobs.json, run logs at <CRON_DIR>/runs/, and
# heartbeat config at <CRON_DIR>/heartbeat/.
# Default: "" (scheduler and heartbeat disabled)
# CRON_DIR=./data/cron

# Maximum number of cron jobs that may execute simultaneously.
# Default: 1
# CRON_MAX_CONCURRENT=1

# Embedding model used for semantic memory search.
# Requires an OpenAI-compatible /v1/embeddings endpoint.
# Default: text-embedding-3-small
# EMBED_MODEL=text-embedding-3-small

# Global default interval between heartbeat runs (Go duration string).
# Individual peers can override this via the heartbeat API.
# Default: 30m
# HEARTBEAT_EVERY=30m

# Globally enable or disable heartbeat runs.
# Default: true
# HEARTBEAT_ENABLED=true

# API key for the configured LLM provider.
LLM_API_KEY=your-api-key-here

# Override the provider base URL. Useful for local proxies or self-hosted
# endpoints that expose an OpenAI-compatible API.
# Default: provider standard URL
# LLM_BASE_URL=http://localhost:11434/v1

# Model to use. Examples:
#   OpenAI: gpt-4o, gpt-4o-mini
#   Anthropic: claude-3-5-sonnet-20241022, claude-3-haiku-20240307
#   OpenRouter: openai/gpt-4o, anthropic/claude-3.5-sonnet
#   NVIDIA NIM: nvidia/llama-3.1-nemotron-70b-instruct, meta/llama-3.1-405b-instruct
LLM_MODEL=gpt-4o

# LLM backend to use. Supported values: openai, anthropic, openrouter, nvidia.
# Default: openai
# LLM_PROVIDER=openai

# TCP address the HTTP server listens on.
# Default: :8080
# LISTEN_ADDR=:8080

# Path to the SQLite database file for long-term semantic memory.
# Default: "" (disabled)
# MEMORY_DB_PATH=./data/memory.db

# Inject top memory hits as a system message on each chat and agent.run request.
# Default: false
# MEMORY_INJECT=false

# Maximum number of memory chunks injected per request.
# Default: 3
# MEMORY_TOP_K=3

# Maximum duration allowed for a single LLM round-trip (Go duration string).
# Default: 2m
# REQUEST_TIMEOUT=2m

# Directory where per-peer .jsonl session files are stored.
# Default: "" (in-memory only)
# SESSION_DIR=./data/sessions

# Maximum number of messages retained in a peer conversation history before
# pruning or compaction.
# Default: 100
# SESSION_MAX_MESSAGES=100

# Number of recent tool-related messages kept in the model-visible request
# context. Older tool chatter stays in the transcript but is pruned before
# inference.
# Default: 8
# SESSION_PRUNE_KEEP_TOOL_MESSAGES=8
